    {
      "mode": "managed",
      "type": "kubernetes_manifest",
      "name": "rmq",
      "provider": "provider[\"registry.terraform.io/hashicorp/kubernetes\"]",
      "instances": [
        {
          "schema_version": 1,
          "attributes": {
            "computed_fields": null,
            "field_manager": [],
            "manifest": {
              "value": {
                "apiVersion": "rabbitmq.com/v1beta1",
                "kind": "RabbitmqCluster",
                "metadata": {
                  "name": "rabbitmq",
                  "namespace": "codeflix"
                },
                "spec": {
                  "affinity": {
                    "nodeAffinity": {
                      "requiredDuringSchedulingIgnoredDuringExecution": {
                        "nodeSelectorTerms": [
                          {
                            "matchExpressions": [
                              {
                                "key": "type",
                                "operator": "In",
                                "values": [
                                  "ec2"
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    }
                  },
                  "persistence": {
                    "storage": "1Gi",
                    "storageClassName": "gp3-storageclass"
                  },
                  "replicas": 1,
                  "resources": {
                    "limits": {
                      "cpu": "500m",
                      "memory": "1Gi"
                    },
                    "requests": {
                      "cpu": "500m",
                      "memory": "1Gi"
                    }
                  }
                }
              },
              "type": [
                "object",
                {
                  "apiVersion": "string",
