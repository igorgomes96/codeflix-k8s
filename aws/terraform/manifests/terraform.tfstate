      "provider": "provider[\"registry.terraform.io/hashicorp/kubernetes\"]",
      "instances": [
        {
          "schema_version": 1,
          "attributes": {
            "computed_fields": null,
            "field_manager": [],
            "manifest": {
              "value": {
                "apiVersion": "apps/v1",
                "kind": "StatefulSet",
                "metadata": {
                  "name": "mysql",
                  "namespace": "codeflix"
                },
                "spec": {
                  "replicas": 1,
                  "selector": {
                    "matchLabels": {
                      "app": "mysql"
                    }
                  },
                  "serviceName": "mysql-h",
                  "template": {
                    "metadata": {
                      "labels": {
                        "app": "mysql"
                      }
                    },
                    "spec": {
                      "containers": [
                        {
                          "env": [
                            {
                              "name": "MYSQL_ROOT_PASSWORD",
                              "value": "root"
                            }
                          ],
                          "image": "mysql",
                          "lifecycle": {
                            "postStart": {
                              "exec": {
                                "command": [
